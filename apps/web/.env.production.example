# ==============================================================================
# SixDegrees Platform — Production Environment Variables
# ==============================================================================
# Copy this file to .env.production.local for local production testing.
# All variables marked [REQUIRED] must be set before deploying to production.
# Set these in the Vercel dashboard under Settings → Environment Variables.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase — [REQUIRED]
# Find these in your Supabase project: Settings → API
# ------------------------------------------------------------------------------

# Your Supabase project URL (safe to expose — scoped by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key (safe to expose — restricted by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key — NEVER expose to the browser
# Used only in server-side code to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ------------------------------------------------------------------------------
# Application — [REQUIRED]
# ------------------------------------------------------------------------------

# The canonical public URL of the production deployment
NEXT_PUBLIC_APP_URL=https://sixdegrees.link

# ------------------------------------------------------------------------------
# Email — [REQUIRED for transactional email]
# Sign up at https://resend.com — add and verify your sending domain
# ------------------------------------------------------------------------------

RESEND_API_KEY=re_<your-resend-api-key>
EMAIL_FROM=noreply@sixdegrees.link

# ------------------------------------------------------------------------------
# AI — [REQUIRED for AI features]
# Get your key at https://console.anthropic.com
# ------------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-<your-anthropic-api-key>

# Maximum daily spend on Claude API calls (USD). Defaults to 10 if unset.
CLAUDE_DAILY_COST_CAP_USD=10

# ------------------------------------------------------------------------------
# Admin — [REQUIRED]
# Comma-separated list of email addresses with admin dashboard access
# ------------------------------------------------------------------------------

ADMIN_EMAILS=admin@sixdegrees.link,sudo@sixdegrees.link
